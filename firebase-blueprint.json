{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user details and roles (Farmer, Admin, Staff).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "nationalId": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "region": { "type": "string" },
        "role": { "type": "string", "enum": ["farmer", "admin", "staff"] },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "profilePhotoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "role", "status"]
    },
    "LandRecord": {
      "title": "Land Record",
      "description": "Stores farmer land ownership details.",
      "type": "object",
      "properties": {
        "farmerUid": { "type": "string" },
        "size": { "type": "number", "description": "Size in acres/hectares" },
        "location": { "type": "string" },
        "farmingType": { "type": "string", "enum": ["crop", "livestock", "mixed"] },
        "crops": { "type": "array", "items": { "type": "string" } },
        "documentUrl": { "type": "string", "description": "Proof of ownership" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["farmerUid", "size", "location", "status"]
    },
    "MarketPrice": {
      "title": "Market Price",
      "description": "Stores crop prices across different markets.",
      "type": "object",
      "properties": {
        "crop": { "type": "string" },
        "region": { "type": "string" },
        "priceLocal": { "type": "number" },
        "priceRegional": { "type": "number" },
        "priceInternational": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["crop", "region", "priceLocal"]
    },
    "Service": {
      "title": "JAMO Service",
      "description": "Available services for farmers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name", "description"]
    },
    "ServiceApplication": {
      "title": "Service Application",
      "description": "Applications submitted by farmers for services.",
      "type": "object",
      "properties": {
        "farmerUid": { "type": "string" },
        "serviceId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["farmerUid", "serviceId", "status"]
    },
    "Payment": {
      "title": "Payment Transaction",
      "description": "Records of payments made by farmers.",
      "type": "object",
      "properties": {
        "farmerUid": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string", "default": "UGX" },
        "method": { "type": "string", "enum": ["Mobile Money", "Bank"] },
        "transactionId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "purpose": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["farmerUid", "amount", "method", "status"]
    },
    "Message": {
      "title": "Inquiry Message",
      "description": "Messages between farmers and admins.",
      "type": "object",
      "properties": {
        "senderUid": { "type": "string" },
        "receiverUid": { "type": "string" },
        "text": { "type": "string" },
        "read": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderUid", "receiverUid", "text"]
    }
  },
  "firestore": {
    "users": { "schema": "UserProfile", "description": "User profiles" },
    "land_records": { "schema": "LandRecord", "description": "Land ownership records" },
    "market_prices": { "schema": "MarketPrice", "description": "Crop prices" },
    "services": { "schema": "Service", "description": "Available services" },
    "applications": { "schema": "ServiceApplication", "description": "Service applications" },
    "payments": { "schema": "Payment", "description": "Payment history" },
    "messages": { "schema": "Message", "description": "In-app messages" }
  }
}
